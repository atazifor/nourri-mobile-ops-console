# Firebase web client config.
#
# Copy this file to `.env.local` and fill in the values from
# Firebase Console → Project settings → Your apps → SDK setup.
#
# Vite only exposes env vars prefixed with `VITE_` to the browser bundle,
# which is why each key is prefixed below. These values are inlined into the
# client JS at build time, so do NOT put server-only secrets here — Firebase
# web config is public by design (gated by Firebase Security Rules).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Used only by `npm run seed`. Must be a Firebase Auth user with a
# matching adminUsers/{uid} doc where role = "ADMIN".
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
